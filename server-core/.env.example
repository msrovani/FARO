# F.A.R.O. Server Core - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no Git

# Aplicação
DEBUG=false
ENVIRONMENT=development

# Segurança - TROQUE OBRIGATORIAMENTE em produção
SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_DE_NO_MINIMO_32_CARACTERES
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Banco de dados PostgreSQL + PostGIS
DATABASE_URL=postgresql+asyncpg://faro:sua_senha_aqui@localhost:5432/faro_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAMS_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# Storage S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=faro-assets
S3_SECURE=false

# CORS - em produção, liste apenas as origens permitidas
CORS_ORIGINS=http://localhost:3000

# Observabilidade (Open Source apenas)
# OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Integrações externas (a implementar)
# SOEWEB_BASE_URL=
# SOEWEB_API_KEY=
# GOVBR_CLIENT_ID=
# GOVBR_CLIENT_SECRET=
