# F.A.R.O. Environment Configuration
# =============================================================================
# COPIE ESTE ARQUIVO PARA .env E CONFIGURE OS VALORES ABAIXO
# =============================================================================

# =============================================================================
# SECURITY - OBRIGATÓRIO
# =============================================================================
# SECRET_KEY: Chave secreta para JWT (mínimo 32 caracteres)
# Em produção: Use uma chave forte e única (ex: openssl rand -hex 32)
# Em desenvolvimento: pode deixar em branco (será usado default seguro)
SECRET_KEY=

# =============================================================================
# DATABASE - OBRIGATÓRIO
# =============================================================================
# DATABASE_URL: URL de conexão PostgreSQL com PostGIS
# Formato: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
# 
# EM PRODUÇÃO:
# - Substitua 'faro_dev_secret' por uma senha forte e única
# - Nunca use 'CHANGE_ME', 'password', 'changeme' ou valores genéricos
# - Use conexão SSL quando disponível
#
# EXEMPLO PRODUÇÃO:
# DATABASE_URL=postgresql+asyncpg://faro:SenhaForte123!@localhost:5432/faro_db
#
# DESENVOLVIMENTO (default seguro):
DATABASE_URL=postgresql+asyncpg://faro:faro_dev_secret@localhost:5432/faro_db

# =============================================================================
# CORS - Configuração de Segurança
# =============================================================================
# CORS_ORIGINS: Origens permitidas (separadas por vírgula)
# EM PRODUÇÃO: Liste explicitamente as origens permitidas
# NUNCA use '*' em produção
#
# EXEMPLO PRODUÇÃO:
# CORS_ORIGINS=https://faro.policia.gov.br,https://intel.faro.gov.br
#
# DESENVOLVIMENTO:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# S3/MinIO Storage (Opcional)
# =============================================================================
# S3_ACCESS_KEY: Chave de acesso AWS/MinIO
# S3_SECRET_KEY: Chave secreta AWS/MinIO
# S3_ENDPOINT: Endpoint S3 (ex: http://localhost:9000)
# S3_BUCKET_NAME: Nome do bucket (default: faro-assets)
# S3_ENABLED: Habilitar S3 (true/false)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=faro-assets
S3_ENABLED=false

# =============================================================================
# Redis (Opcional - recomendado para produção)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_STREAMS_URL=redis://localhost:6379/1
REDIS_CACHE_URL=redis://localhost:6379/2

# =============================================================================
# Observability (Opcional)
# =============================================================================
# SENTRY_DSN: DSN para error tracking (ex: https://xxx@yyy.ingest.sentry.io/zzz)
# OTLP_ENDPOINT: Endpoint OpenTelemetry (ex: http://localhost:4318/v1/traces)
SENTRY_DSN=
OTLP_ENDPOINT=

# =============================================================================
# Environment
# =============================================================================
# ENVIRONMENT: Ambiente de execução (development, staging, production)
# DEBUG: Modo debug (true/false) - NUNCA true em produção
ENVIRONMENT=development
DEBUG=false

# =============================================================================
# NOTAS DE SEGURANÇA
# =============================================================================
# 1. Nunca commite o arquivo .env real (apenas .env.example)
# 2. Em produção, todas as chaves devem ser únicas e fortes
# 3. Use um gerenciador de secrets (AWS Secrets Manager, Vault, etc.) quando possível
# 4. Rotacione credenciais regularmente
# 5. Verifique se o arquivo .env tem permissões restritas (chmod 600)
# =============================================================================